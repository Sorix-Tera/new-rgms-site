<main class="page ae-map-page" id="aeMapPage">
  <section class="ae-map-shell">
    <div class="ae-map-toolbar">
      <div class="ae-map-toolbar-left">
        <h1 class="ae-map-title">Abyssal Expedition Map</h1>
        <div class="ae-map-count">
          Selected tiles: <strong id="aeMapCount">0</strong>
        </div>
      </div>

      <div class="ae-map-toolbar-right">
        <button type="button" class="ae-map-btn" id="aeMapResetView">Reset view</button>
        <button type="button" class="ae-map-btn" id="aeMapClear">Clear selection</button>
        <div class="ae-map-hint">Wheel = zoom · Drag = move</div>
      </div>
    </div>

    <div class="ae-map-viewport ae-map-loading" id="aeMapViewport">
      <div>Loading map…</div>
    </div>
  </section>
</main>

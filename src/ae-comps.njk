---
layout: layouts/base.njk
title: "AE Comps · TangledSpore's RGMs!"
permalink: "ae-comps/index.html"
extraHead: '<link rel="stylesheet" href="/css/ae-comps.css" />'
extraScripts: '<script src="/js/ae-comps.js" defer></script>'
---

<main class="page ae-page" id="aePage">
  <header class="page-header">
    <h1 class="page-title">AE Comps</h1>
    <p class="page-subtitle">
      Private builder and finder for Abyssal Expedition boss comps.
    </p>
  </header>

  <section class="ae-tabs-wrap" aria-label="AE tools">
    <div class="cf-tabs ae-tabs" role="tablist" aria-label="AE tools">
      <button class="cf-tab ae-tab is-active" id="aeTabBuilder" role="tab" aria-selected="true" aria-controls="aePanelBuilder" data-target="builder">
        Comp Builder
      </button>
      <button class="cf-tab ae-tab" id="aeTabFinder" role="tab" aria-selected="false" aria-controls="aePanelFinder" data-target="finder">
        Comp Finder
      </button>
    </div>

    <section class="ae-panel is-active" id="aePanelBuilder" role="tabpanel" aria-labelledby="aeTabBuilder" data-panel="builder">
      <div id="aeCompBuilder" class="ae-builder-card">
        <div class="ae-builder-top">
          <div class="ae-slots" id="aeSlots">
            {% for i in [1,2,3,4,5] %}
              <button
                type="button"
                class="ae-slot"
                data-slot-index="{{ i - 1 }}"
                data-slot-type="hero"
                aria-label="Hero slot {{ i }}"
              >
                <span class="ae-slot-empty-label">Hero {{ i }}</span>
              </button>
            {% endfor %}
            <button
              type="button"
              class="ae-slot ae-slot-pet"
              data-slot-index="5"
              data-slot-type="pet"
              aria-label="Pet slot"
            >
              <span class="ae-slot-empty-label">Pet</span>
            </button>
          </div>

          <div class="ae-builder-actions">
            <label class="ae-damage-field" for="aeDamage">
              <span class="ae-field-label">Damage</span>
              <div class="ae-damage-input-wrap">
                <input
                  id="aeDamage"
                  name="damage"
                  type="number"
                  step="0.1"
                  min="0"
                  inputmode="decimal"
                  placeholder="0.0"
                />
                <span class="ae-damage-unit">b</span>
              </div>
            </label>

            <button type="button" id="aeSendBtn" class="ae-send-btn">Send</button>
          </div>

          <p id="aeBuilderMessage" class="page-status ae-builder-message" aria-live="polite"></p>
        </div>

        <div class="ae-picker-layout">
          <section class="ae-library-card ae-library-heroes" aria-label="Heroes">
            <div class="ae-library-head">
              <h2 class="page-section-title">Heroes</h2>
            </div>
            <div class="ae-icon-grid ae-hero-grid" id="aeHeroGrid"></div>
          </section>

          <section class="ae-library-card ae-library-pets" aria-label="Pets">
            <div class="ae-library-head">
              <h2 class="page-section-title">Pets</h2>
            </div>
            <div class="ae-icon-grid ae-pet-grid" id="aePetGrid"></div>
          </section>
        </div>
      </div>
    </section>

    <section class="ae-panel" id="aePanelFinder" role="tabpanel" aria-labelledby="aeTabFinder" data-panel="finder" hidden>
      <div id="aeCompFinder" class="ae-finder-wrap">
        <div class="ae-finder-summary">
          <div class="chart-card ae-summary-card">
            <div class="ae-summary-inner">
              <span class="ae-summary-label">Best box total</span>
              <strong id="aeFinderBestTotal" class="ae-summary-value">—</strong>
            </div>
          </div>
        </div>

        <p id="aeFinderStatus" class="page-status">Open this tab to load saved comps.</p>
        <div id="aeFinderBoxes" class="ae-finder-boxes"></div>
      </div>
    </section>
  </section>
</main>

---
layout: layouts/base.njk
title: "AE Comps · TangledSpore's RGMs!"
permalink: "ae-comps.html"
extraHead: '<link rel="stylesheet" href="/css/ae-comps.css" />'
extraScripts: '<script src="/js/ae-comps.js" defer></script>'
---

<main class="page ae-comps-page">
  <header class="page-header ae-comps-header">
    <h1 class="page-title">AE Comps</h1>
    <p class="page-subtitle">Private builder for testing and saving Abyssal Expedition boss comps.</p>

    <div class="ae-tabs" role="tablist" aria-label="AE comp tools">
      <button
        type="button"
        class="ae-tab is-active"
        role="tab"
        id="aeTabBuilder"
        aria-selected="true"
        aria-controls="aePanelBuilder"
        data-target="builder"
      >
        Comp Builder
      </button>
      <button
        type="button"
        class="ae-tab"
        role="tab"
        id="aeTabOther"
        aria-selected="false"
        aria-controls="aePanelOther"
        data-target="other"
      >
        Tab 2
      </button>
    </div>
  </header>

  <section
    class="ae-tab-panel is-active"
    role="tabpanel"
    id="aePanelBuilder"
    aria-labelledby="aeTabBuilder"
    data-panel="builder"
  >
    <div id="aeCompBuilder" class="ae-builder">
      <div class="ae-builder-card">
        <div class="ae-slots-wrap">
          <div class="ae-slots" id="aeSlots">
            {% for i in [1,2,3,4,5] %}
              <button
                type="button"
                class="ae-slot hero-slot"
                data-slot-index="{{ i - 1 }}"
                data-slot-type="hero"
                aria-label="Hero slot {{ i }}"
              >
                <span class="ae-slot-label">Hero {{ i }}</span>
              </button>
            {% endfor %}

            <button
              type="button"
              class="ae-slot pet-slot"
              data-slot-index="5"
              data-slot-type="pet"
              aria-label="Pet slot"
            >
              <span class="ae-slot-label">Pet</span>
            </button>
          </div>

          <div class="ae-submit-row">
            <label class="ae-damage-field" for="aeDamage">
              <span>Damage</span>
              <input
                id="aeDamage"
                name="damage"
                type="number"
                step="any"
                inputmode="decimal"
                placeholder="e.g. 12.75"
              />
            </label>

            <button type="button" id="aeSendBtn" class="ae-send-btn">Send</button>
          </div>

          <p id="aeBuilderMessage" class="ae-builder-message" aria-live="polite"></p>
        </div>
      </div>

      <div class="ae-picker-grid">
        <section class="ae-icon-panel heroes-panel">
          <div class="ae-panel-head">
            <h2>Heroes</h2>
            <span id="aeHeroCount">0</span>
          </div>
          <div class="ae-icons-grid heroes-grid" id="aeHeroGrid"></div>
        </section>

        <section class="ae-icon-panel pets-panel">
          <div class="ae-panel-head">
            <h2>Pets</h2>
            <span id="aePetCount">0</span>
          </div>
          <div class="ae-icons-grid pets-grid" id="aePetGrid"></div>
        </section>
      </div>
    </div>
  </section>

  <section
    class="ae-tab-panel"
    role="tabpanel"
    id="aePanelOther"
    aria-labelledby="aeTabOther"
    data-panel="other"
    hidden
  >
    <div class="ae-builder-card ae-placeholder-card">
      <p>Second tab placeholder. We can wire this next.</p>
    </div>
  </section>
</main>
